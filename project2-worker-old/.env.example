PROJECT1_BASE_URL=http://localhost:3000
PROJECT1_API_KEY=replace_with_shared_secret
BATCH_SIZE=100
WORKER_COUNT=8
EMPTY_QUEUE_SLEEP_MINUTES=3
LOOP_DELAY_MS=1000
LEADID_WAIT_MS=6000
PRE_SUBMIT_WAIT_MS=0
TARGET_FORM_URL=https://chattershealthsolutions.com
# Under WSL, localhost is rewritten to the Windows host IP (see /etc/resolv.conf). Set false to disable.
WSL_LOCALHOST_REWRITE=true
# When URL has no #fragment, append #contact so the lead form section is targeted (set empty to disable).
TARGET_FORM_HASH=contact
FORM_WAIT_MS=90000
NAVIGATION_TIMEOUT_MS=120000
PLAYWRIGHT_IGNORE_HTTPS_ERRORS=true
# Space-separated extra Chromium flags. Leave unset for sensible defaults on WSL (adds --no-sandbox).
PLAYWRIGHT_CHROMIUM_ARGS=
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_DEVTOOLS=false
PLAYWRIGHT_SLOWMO_MS=0
PLAYWRIGHT_USER_AGENT=
DEFAULT_ZIP_CODE=80203

# Console A→Z trace (default on). Set to false to only keep JSONL lines.
WORKER_VERBOSE_LOG=true

# Oxylabs: placeholders USERNAME / PASSWORD / replaceMe in zips_lookup.db `url` column
# Preferred: OXYLABS_USERNAME + OXYLABS_PASSWORD. Also accepted: userName + password (lowercase keys in .env).
OXYLABS_USERNAME=
OXYLABS_PASSWORD=
userName=
password=
# Optional: full line if ZIP not in DB (same format as DB `url` after substitution)
OXYLABS_PROXY=
OXYLABS_ROTATE_SESSION=true
# Optional: override path to SQLite (default: ../zips_lookup.db from repo root)
ZIPS_LOOKUP_DB=

# Repo-root .env.local is also loaded (override) so you can share Next secrets.

# CSS selectors on Chatters Health Solutions form
FORM_SELECTOR=form
FIELD_FIRSTNAME_SELECTOR=input[name="firstName"]
FIELD_LASTNAME_SELECTOR=input[name="lastName"]
FIELD_EMAIL_SELECTOR=input[name="email"]
FIELD_PHONE_SELECTOR=input[name="phone"]
FIELD_ZIPCODE_SELECTOR=input[name="zipCode"]
FIELD_CONSENT_SELECTOR=input#leadid_tcpa_disclosure
SUBMIT_SELECTOR=button[type="submit"]
