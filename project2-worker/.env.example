# MongoDB (same as Next.js app)
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=chatters-health

# Project 1 (Next app): base URL for APIs and default origin if TARGET_FORM_URL unset
PROJECT1_BASE_URL=http://localhost:3000
PROJECT1_API_KEY=my_super_secret_123

# Form Playwright opens (hash anchors to #contact). Falls back to PROJECT1_BASE_URL / FORM_BASE_URL.
TARGET_FORM_URL=http://localhost:3000
# TARGET_FORM_URL=https://chattershealthsolutions.com

# Legacy alias for TARGET_FORM_URL (optional)
# FORM_BASE_URL=http://localhost:3000

# Prefetched leased jobs in memory (cap before workers drain the queue)
BATCH_SIZE=10

# Parallel Playwright workers
WORKER_COUNT=2

# When nothing is claimable, all workers sleep this many minutes before retrying
EMPTY_QUEUE_SLEEP_MINUTES=1

# Pause after each job finishes (before next claim / shift)
LOOP_DELAY_MS=1000

# Oxylabs credentials (substituted into zips.url as USERNAME / PASSWORD)
userName=your_oxylabs_username
password=your_oxylabs_password

# SQLite DB (repo root or custom path)
ZIPS_DB_PATH=../zips_lookup.db

# Playwright
HEADLESS=true

# Localhost + Oxylabs: traffic would go to the proxy exit's "localhost", not your PC.
# Default: skip browser proxy when TARGET_FORM_URL is localhost / 127.0.0.1.
SKIP_PROXY_FOR_LOCALHOST=true
# Set true to always use Oxylabs in the browser (needs a public URL or tunnel, not real localhost).
FORCE_PLAYWRIGHT_PROXY=false

# How long a claimed submission stays locked if the worker dies (ms)
WORKER_LEASE_MS=900000
